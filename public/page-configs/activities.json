              "label": "Call",
              "value": "Call"
            },
            {
              "label": "Email",
              "value": "Email"
            },
            {
              "label": "Meeting",
              "value": "Meeting"
            },
            {
              "label": "Demo",
              "value": "Demo"
            },
            {
              "label": "Note",
              "value": "Note"
